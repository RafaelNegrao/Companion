{
  "name": "companion-app",
  "version": "1.0.5",
  "description": "App lateral que abre ao passar o mouse",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.companion.app",
    "productName": "Companion",
    "artifactName": "${productName}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/garantia.ico",
      "target": "portable"
    }
  },
  "keywords": [
    "electron",
    "sidebar",
    "companion"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0"
  }
}
